# ~/.pi — track only self-authored config; ignore runtime/installed stuff.

# --- Top-level runtime dirs (regenerated by pi / installers) ---
.pi/
envs/
remote/
remote-pi/
skills/
skills-lock.json

# --- agent/: ignore everything, then descend only into what we own ---
agent/*
!agent/extensions/
!agent/prompts/
!agent/settings.json

# extensions/: ignore all, whitelist only self-authored extensions
agent/extensions/*
!agent/extensions/aws-sso-auto-relogin.ts
!agent/extensions/slim-ui.ts

# prompts/: tracked entirely (dir whitelisted above)
